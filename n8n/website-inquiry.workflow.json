    "Recent (1h)": { "main": [[{ "node": "Abuse Check", "type": "main", "index": 0 }]] },
    "Abuse Check": { "main": [[{ "node": "Save Inquiry", "type": "main", "index": 0 }]] },
    "Save Inquiry": { "main": [[{ "node": "Send Reply?", "type": "main", "index": 0 }]] },
