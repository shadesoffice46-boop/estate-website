# ─────────────────────────────────────────────────────────────────────────
# Environment variables for the ESTATE site.
#
# Copy this file to `.env.local` ON THE VPS ONLY and fill in real values.
# `.env.local` is gitignored and must NEVER be committed. Secrets live on the
# server, never in this repository.
# ─────────────────────────────────────────────────────────────────────────

# Production URL of the n8n "inquiry" Webhook node (server-side only —
# never exposed to the browser).
N8N_INQUIRY_WEBHOOK_URL=

# Shared secret sent as the "x-webhook-secret" header on every forward.
# n8n verifies this so a leaked webhook URL alone cannot trigger the flow.
# Generate a long random value, e.g.:  openssl rand -hex 32
N8N_WEBHOOK_SECRET=
